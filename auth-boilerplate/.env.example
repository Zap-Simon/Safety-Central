# Microsoft Azure Authentication Configuration
# Copy this file to .env and fill in your actual values

# Azure AD Application Registration Details
# Get these from your Azure App Registration in the Azure Portal
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Application URLs
# Update these with your actual domain/URL
VITE_AZURE_REDIRECT_URI=https://your-domain.com
AZURE_REDIRECT_URI=https://your-domain.com

# Database Configuration (if using a database)
DATABASE_URL=postgresql://username:password@localhost:5432/your_database

# OpenAI Configuration (if using AI features)
OPENAI_API_KEY=your-openai-api-key-here

# SharePoint Configuration (if using SharePoint integration)
# Update with your actual SharePoint domain
SHAREPOINT_SITE_URL=https://your-company.sharepoint.com
SHAREPOINT_TENANT_ID=your-tenant-id-here

# Environment
NODE_ENV=development

# Server Configuration
PORT=5000